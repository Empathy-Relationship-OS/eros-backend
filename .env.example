POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# AWS S3 (photo uploads)
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=eros-photos
AWS_CDN_BASE_URL=
